; ============================================================================
; Step 23: Uniqueness of Sym-Invariant Measure
; ============================================================================
; On a finite set of n truth classes, the symmetry group Sym(n) acts by
; permuting classes. A probability measure mu is Sym-invariant iff
; mu(sigma(i)) = mu(i) for all sigma in Sym(n) and all classes i.
;
; The UNIQUE such measure is the uniform distribution: mu(i) = 1/n for all i.
;
; Model: 3 truth classes {0, 1, 2} with Sym(3) acting.
; Weights represented as integers (w0, w1, w2) summing to a total W > 0.
; Invariance under Sym(3) forces w0 = w1 = w2.
;
; We verify:
;   Part 1: Uniform measure (w0 = w1 = w2 = 1) is Sym-invariant (sat)
;   Part 2: Non-uniform measure + Sym(3) invariance = contradiction (unsat)
;   Part 3: Invariance under transpositions alone forces uniformity (unsat)
; ============================================================================

(set-logic ALL)
(set-option :produce-models true)

; ---------- 3 truth classes with weights ----------
(declare-fun w (Int) Int)

; Weights must be positive (representing probability * W)
(assert (> (w 0) 0))
(assert (> (w 1) 0))
(assert (> (w 2) 0))

; ---------- Sym(3) permutations ----------
; Sym(3) is generated by two transpositions: (01) and (12)
; Full group: {e, (01), (02), (12), (012), (021)}
;
; Invariance: w(sigma(i)) = w(i) for all sigma, i
;
; Under (01): w(0) = w(1), w(1) = w(0), w(2) = w(2)
; Under (12): w(0) = w(0), w(1) = w(2), w(2) = w(1)
; Together: w(0) = w(1) = w(2)

; ---------- Part 1: Uniform measure is Sym-invariant ----------
(push 1)

; Set uniform weights
(assert (= (w 0) 1))
(assert (= (w 1) 1))
(assert (= (w 2) 1))

; Invariance under (01): w(0) = w(1)
(assert (= (w 0) (w 1)))
; Invariance under (12): w(1) = w(2)
(assert (= (w 1) (w 2)))

(echo "--- Part 1: Uniform measure is Sym(3)-invariant ---")
(echo "Expected: sat")
(check-sat)
(pop 1)

; ---------- Part 2: Non-uniform + invariance = contradiction ----------
(push 1)

; Invariance under transposition (01): w(0) = w(1)
(assert (= (w 0) (w 1)))
; Invariance under transposition (12): w(1) = w(2)
(assert (= (w 1) (w 2)))

; Assert non-uniformity: some weight differs
(assert (or (not (= (w 0) (w 1)))
            (not (= (w 1) (w 2)))
            (not (= (w 0) (w 2)))))

(echo "--- Part 2: Non-uniform + Sym(3)-invariance? ---")
(echo "Expected: unsat")
(check-sat)
(pop 1)

; ---------- Part 3: Transpositions alone force uniformity ----------
; Even without enumerating all 6 elements of Sym(3), the two generators
; (01) and (12) suffice to force w0 = w1 = w2.
(push 1)

; Only impose generator invariance
; Generator (01): w(0) = w(1)
(assert (= (w 0) (w 1)))
; Generator (12): w(1) = w(2)
(assert (= (w 1) (w 2)))

; Try to find w(0) != w(2) (should be impossible)
(assert (not (= (w 0) (w 2))))

(echo "--- Part 3: Transpositions force full uniformity? ---")
(echo "Expected: unsat")
(check-sat)
(pop 1)

(echo "--- Step 23 verification complete (3 parts) ---")
