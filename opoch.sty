% ===== Theorem Environments =====
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{axiom}{Axiom}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
\newtheorem{example}[theorem]{Example}

% ===== Opoch-Specific Commands =====

% Primitives
\newcommand{\Pit}{\Pi}              % Truth
\newcommand{\Del}{\Delta}           % Tests/Distinctions
\newcommand{\Tim}{\mathcal{T}}      % Time
\newcommand{\Carrier}{\mathcal{D}^*}% Carrier set D* = {0,1}^{<\infty}
\newcommand{\Ledger}{\mathcal{L}}   % Ledger
\newcommand{\UTM}{\mathcal{U}}      % Universal Turing Machine

% Null-State Logic
\newcommand{\UNIQUE}{\textsc{unique}}
\newcommand{\OMEGA}{\Omega}
\newcommand{\UNSAT}{\textsc{unsat}}
\let\REFUTED\UNSAT % backward-compat alias
\newcommand{\trit}[1]{\langle #1 \rangle}

% Truth quotient
\newcommand{\TQ}[1]{\Pi^*(#1)}
\newcommand{\equivL}{\equiv_{\Ledger}}

% Fiber and gauge
\newcommand{\fiber}[1]{W(#1)}
\newcommand{\gauge}{\mathcal{G}_\Tim}

% Nothingness
\newcommand{\noth}{\bot}
\newcommand{\opnoth}{\bot_{\mathrm{op}}}

% Problem 5-tuple
\newcommand{\Problem}{\langle \mathcal{Q}, \mathcal{A}, \mathcal{V}, B, \pi \rangle}

% Diamond law
\newcommand{\Noise}{\mathcal{N}}
\newcommand{\Query}{\mathcal{Q}}

% Bellman
\newcommand{\Bellman}{\mathcal{B}}
\newcommand{\argmin}{\operatornamewithlimits{argmin}}
\newcommand{\argmax}{\operatornamewithlimits{argmax}}

% ===== Derivation Commands (Steps 0--33) =====

% Observable Opens and Eraser Algebra
\newcommand{\ObsOpen}{\mathcal{O}^{\mathrm{fin}}_\Delta}
\newcommand{\Eraser}{\mathcal{E}}

% Self-Generating Fixed Point
\newcommand{\FixPt}{\Upsilon}

% Myhill-Nerode Congruence
\newcommand{\MNcong}{\equiv_q}

% Separator Geometry
\newcommand{\SepDist}{d_q}

% Self-Hosting
\newcommand{\SelfHost}{\Upsilon(\mathcal{S})}

% Self-Delimiting Map
\newcommand{\SdMap}{\mathrm{sd}}

% Canonical Enumeration
\newcommand{\CanEnum}{E_\Delta}

% Closure Rules
\newcommand{\ClMin}{\mathrm{Cl}_{\min}}

% Finite Slice
\newcommand{\FinSlice}{D_0}

% Exactness Gate
\newcommand{\ExactGate}{\mathcal{G}_{\mathrm{ex}}}

% Energy Ledger
\newcommand{\Efficiency}{\varepsilon}
\newcommand{\EnergyLedger}{\mathcal{L}_E}

% Decision/Epistemic Regimes
\newcommand{\Epistemic}{\mathcal{R}_{\mathrm{ep}}}
\newcommand{\Decision}{\mathcal{R}_{\mathrm{dec}}}

% Curvature and Hardness
\newcommand{\SepCurv}{\kappa}
\newcommand{\Hardness}{\mathcal{H}}

% Pi-Canonicalization and supporting commands
\newcommand{\PiCanon}{\Pi_{\mathrm{can}}}
\newcommand{\Ser}{\mathrm{Ser}}
\newcommand{\Adm}{\mathrm{Adm}}
\newcommand{\Instrument}{\mathcal{I}}

% Coupling Law (Separator-Indistinguishability Coupling)
\newcommand{\AnsQuot}[2]{\mathrm{Ans}(#1,\, #2)}       % Answer quotient Ans(q, W_a)
\newcommand{\RefGain}[2]{\Delta\Tim_{#1}(#2)}            % Refinement gain DeltaT_q(tau; W)
\newcommand{\EffQ}[2]{\varepsilon(#1;\, #2)}             % Efficiency epsilon(tau; W)
\newcommand{\OptTest}[2]{\tau^*(#1,\, #2)}               % Optimal test tau*(q, W)
\newcommand{\OmegaDist}[2]{d(#1;\, #2)}                  % Omega distance d(q; W)

% Truthpoint, Opoch, Contract aliases
\newcommand{\Truthpoint}{\Pi_\infty}
\newcommand{\Opoch}{\textsc{Opoch}}
\newcommand{\Contract}{\Problem}

% ===== Phase I: Universal Execution Commands =====

% Universal Closure Operator
\newcommand{\UnivOp}{\mathbb{K}}                              % Universal operator K
\newcommand{\TritValuate}{\mathrm{TritVal}}                   % TritValuate operator
\newcommand{\Fact}{\mathrm{Fact}}                              % Factorization operator
\newcommand{\NormOp}{\mathrm{N}}                               % Normalization operator
\newcommand{\GaugeOp}{\Gamma}                                  % Gauge collapse operator
\newcommand{\IndistOp}{\Phi}                                   % Indistinguishability closure

% Closure-Defect
\newcommand{\ClosureDefect}[1]{\Delta_{#1}}                    % Closure-defect Delta_Q
\newcommand{\Residue}{r}                                       % Unresolved residue

% Consciousness Projector
\newcommand{\ConsProj}{\mathfrak{c}}                           % Consciousness projector c
\newcommand{\ConsMeasure}{C}                                   % Consciousness measure

% Trit Field and Valuation State
\newcommand{\TritField}{\theta}                                % Trit field theta
\newcommand{\PrimeBasis}{\mathrm{PrimeBasis}}                  % Prime basis set
\newcommand{\ValState}{(m, \theta, r)}                         % Valuation state triple

% Algebraic Structure
\newcommand{\IndepComp}{\otimes}                               % Independent composition
\newcommand{\NormAlg}{\hat{M}}                                 % Normalized distinguished algebra
\newcommand{\CostGrade}{c}                                     % Cost grading
\newcommand{\PrimeSpec}{\mathrm{Spec}_P}                       % Prime spectrum

% Globally Glued Field
