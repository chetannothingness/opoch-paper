\newcommand{\ObstAlg}{\mathfrak{O}}                            % Obstruction algebra
\newcommand{\RankCollapse}{\mathrm{dim}_{\mathrm{eff}}}        % Effective dimension (rank collapse)

% ===== A0*-Complete Closure: Ordered Witness Algebra =====

% Ordered witness algebra and ledger
\newcommand{\WitAlg}{\mathcal{A}_W}                            % Ordered witness *-algebra
\newcommand{\OrdLedger}{\mathcal{L}_{\mathrm{ord}}}            % Ordered ledger
\newcommand{\WitCompose}{\mathbin{\vartriangleright}}           % Ordered witness composition
\newcommand{\WitCommutator}[2]{[\,#1,\,#2\,]}                  % Witness commutator [e_i, e_j]

% Witness cost splitting
\newcommand{\Ksep}{K_{\mathrm{sep}}}                           % Separative (reversible) cost
\newcommand{\Kdiss}{K_{\mathrm{diss}}}                         % Dissipative (irreversible) cost
\newcommand{\dsep}{d_{\mathrm{sep}}}                           % Symmetric separative distance
\newcommand{\dtime}{\tau_{\mathrm{dir}}}                       % Directed time quasi-metric

% Witness category
\newcommand{\WitCat}{\mathbf{C}_W}                             % Witness path category
\newcommand{\WitPath}{\gamma}                                   % Witness path

% C*-algebra and GNS
\newcommand{\CstarW}{\overline{\WitAlg}}                       % C*-completion of witness algebra
\newcommand{\GNS}{\mathrm{GNS}}                                % GNS construction
\newcommand{\HilbW}{H_\omega}                                  % GNS Hilbert space
\newcommand{\piGNS}{\pi_\omega}                                % GNS representation map
\newcommand{\OmVec}{\Omega_\omega}                             % GNS cyclic vector
\newcommand{\GNSstate}{\omega}                                 % GNS state functional

% Context algebra and Born rule
\newcommand{\Context}{\mathsf{C}}                              % Context (maximal commuting family)
\newcommand{\EventAlg}{\mathcal{E}_Q}                          % Event algebra
\newcommand{\BornProb}{P}                                      % Born probability

% Witness generator decomposition
\newcommand{\WitGen}{A}                                        % Local witness generator
\newcommand{\WitSym}{S}                                        % Symmetric part (gives metric)
\newcommand{\WitAnti}{K}                                       % Antisymmetric part (gives symplectic)

% Center of witness algebra
\newcommand{\CenterW}{Z(\WitAlg)}                              % Center of witness algebra
\newcommand{\OmegaCl}{\Omega_{\mathrm{cl}}}                    % Classical base manifold

% Replay-completeness
\newcommand{\ReplayComplete}{\mathrm{RC}}                      % Replay-completeness property

% Physics sector commands
\newcommand{\Lphase}{L_{\mathrm{phase}}}                       % Phase fiber (rank 1)
\newcommand{\Eweak}{E_{\mathrm{weak}}}                         % Weak fiber (rank 2)
\newcommand{\Ccolor}{C_{\mathrm{color}}}                       % Color fiber (rank 3)

